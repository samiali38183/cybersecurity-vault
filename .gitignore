# ============================================================
# Public repo = portfolio OUTPUT only.
# Anything that's prep / study / personal / process stays LOCAL.
# ============================================================

# ── Personal / sensitive ──
09-Career-Private/
10-DHS-Internship-Private/

# ── All planning, dashboards, daily process work ──
00-Dashboard/

# ── Study / prep folders (study notes, not portfolio output) ──
01-Phase-0-3-Foundation/
02-Phase-3-6-SOC-Skills/
03-Phase-6-12-Specialization/
04-Phase-12-24-Advanced/
05-Certifications/
06-Labs-and-Platforms/

# ── Python practice / scratch / learning (NOT portfolio) ──
08-Projects/Python-Practice/
08-Projects/*/scratch/
08-Projects/*/notes-private/

# ── Secrets / credentials — NEVER commit these ANYWHERE ──
.env
.env.*
*.pem
*.key
*credentials*
*secret*
config.local.*

# ── Python runtime / build artifacts (any project, anywhere) ──
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/
*.egg-info/
build/
dist/

# ── IDE / editor state ──
.vscode/
.idea/
*.swp
*.swo

# ── Jupyter / data ──
.ipynb_checkpoints/

# ── Obsidian internal state (personal, not portable) ──
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache/

# ── OS junk ──
.DS_Store
Thumbs.db
desktop.ini

# ── Temp / logs ──
*.tmp
*.log
